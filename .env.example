# Supabase (للاتصال بقاعدة البيانات - اختياري في المرحلة الأولى)
# في المرحلة الأولى، يعمل الموقع بالكامل عبر localStorage ولا يحتاج Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# الموقع
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
NEXT_PUBLIC_SITE_NAME=طبّك - منصتك الطبية في الأردن

# ملاحظة: يعمل الموقع حالياً بدون Supabase
# كل البيانات تُخزن في متصفح المستخدم (localStorage)
# لمشاهدة الموقع: npm run dev
